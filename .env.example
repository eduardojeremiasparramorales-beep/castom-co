# ============================================
# CASTOM.CO - Variables de Entorno (EJEMPLO)
# Copia este archivo como .env y rellena los valores
# ============================================

# --- Base de Datos PostgreSQL ---
# Crea una base de datos PostgreSQL (puedes usar Neon, Supabase, Railway, AWS RDS, etc.)
DATABASE_URL="postgresql://usuario:password@host:5432/nombre_db?connect_timeout=15"

# --- NextAuth (Autenticación) ---
# Genera un secreto seguro con: openssl rand -base64 32
NEXTAUTH_SECRET="tu_secreto_generado_aqui"
# URL de tu app (en local: http://localhost:3000 ; en producción: https://castom.co)
NEXTAUTH_URL="http://localhost:3000"

# --- Almacenamiento de Imágenes (AWS S3 o compatible) ---
# Necesitas un bucket S3 (AWS) o compatible (Cloudflare R2, MinIO, etc.)
AWS_REGION="us-west-2"
AWS_BUCKET_NAME="tu-bucket-name"
AWS_FOLDER_PREFIX="castom/"
AWS_ACCESS_KEY_ID="tu_access_key"
AWS_SECRET_ACCESS_KEY="tu_secret_key"

# --- Nequi (Pago directo) ---
# Tu número de Nequi para recibir pagos
NEXT_PUBLIC_NEQUI_PHONE="3000000000"
NEXT_PUBLIC_NEQUI_NAME="Tu Nombre"
